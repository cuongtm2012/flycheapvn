# FlyCheapVN - Environment Variables

# BẮT BUỘC
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# API SOURCES (xoay vòng tự động - cần ÍT NHẤT 1)
# Priority 1: Fly Scraper (RapidAPI) - 250 req/tháng free
# Đăng ký: https://rapidapi.com/ → search "fly-scraper"
RAPIDAPI_KEY=

# Priority 2: Kiwi/Tequila - 500 req/ngày free
# Đăng ký: https://docs.kiwi.com/ (key sandbox 'picky' CHỈ demo, không search thật)
# Dùng 'picky' để test cơ bản, nhưng search thật cần key riêng
KIWI_API_KEY=picky

# Priority 3: Amadeus Self-Service - 2,000 req/tháng free
# Đăng ký: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Priority 4: Skyscanner (RapidAPI) - dùng chung key với RapidAPI
# (tự động dùng RAPIDAPI_KEY)

# Priority 5: Aviasales/Travelpayouts - cached prices free
# Đăng ký: https://www.travelpayouts.com/
TRAVELPAYOUTS_TOKEN=

# Priority 6: SerpAPI Google Flights - 100 req/tháng free
# Đăng ký: https://serpapi.com/
SERPAPI_KEY=

# Priority 7: Google Flights Scraper (Playwright) - không cần key
# Cài: pip install playwright && playwright install chromium
# Tắt: GOOGLE_FLIGHTS_SCRAPER=0
GOOGLE_FLIGHTS_SCRAPER=1

# OPTIONAL
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
FLY_SCRAPER_HOST=fly-scraper.p.rapidapi.com
